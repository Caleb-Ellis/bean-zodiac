---
import { getEntry } from "astro:content";
import Layout from "../layouts/Layout.astro";
import "../styles/global.css";
import { getBeanZodiacForYear, getBeanYear } from "../lib/zodiac";

const currentBeanYear = getBeanYear(new Date());

const zodiacs = Array.from({ length: 121 }, (_, i) =>
  getBeanZodiacForYear(currentBeanYear - 60 + i),
);

const zodiacEntries = await Promise.all(
  zodiacs.map(async (zodiac) => {
    const [bean, flavour] = await Promise.all([
      getEntry("beans", zodiac.beanSlug),
      getEntry("flavours", zodiac.flavourSlug),
    ]);

    if (!bean || !flavour) {
      throw new Error(
        `Missing content for zodiac: ${zodiac.beanSlug} / ${zodiac.flavourSlug}`,
      );
    }

    return { bean, flavour, zodiac };
  }),
);
---

<Layout title="Calendar" description="120 years of beans.">
  <section class="calendar-header">
    <h1>The Bean Zodiac Calendar</h1>
  </section>

  <table class="calendar-table">
    <thead>
      <tr>
        <th>Period</th>
        <th>Bean</th>
        <th>Flavour</th>
      </tr>
    </thead>
    <tbody>
      {
        zodiacEntries.map(({ bean, flavour, zodiac }) => (
          <tr class:list={[{ current: zodiac.beanYear === currentBeanYear }]}>
            <td class="period">
              {zodiac.beanYear === currentBeanYear && (
                <span class="current-badge">Now</span>
              )}
              <a href={`/zodiac/${zodiac.beanYear}`}>
                {zodiac.startDate} - {zodiac.endDate}
              </a>
            </td>
            <td>
              <a href={`/beans/${bean.id}`} style={`color: ${bean.data.color}`}>
                {bean.data.name}
              </a>
            </td>
            <td>
              <a
                href={`/flavours/${flavour.id}`}
                style={`color: ${flavour.data.color}`}
              >
                {flavour.data.name}
              </a>
            </td>
          </tr>
        ))
      }
    </tbody>
  </table>
</Layout>

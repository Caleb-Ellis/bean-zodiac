---
import { getCollection } from "astro:content";
import ZodiacCalendar from "../components/ZodiacCalendar";
import Layout from "../layouts/Layout.astro";
import { buildZodiacData } from "../lib/zodiac";
import "../styles/global.css";

const beanCollection = await getCollection("beans");
const flavourCollection = await getCollection("flavours");
const zodiacCollection = await getCollection("zodiacs");

const data = buildZodiacData(
  beanCollection,
  flavourCollection,
  zodiacCollection,
);
---

<Layout
  title="Which Bean are You?"
  description="Pick a date and find your bean."
>
  <section class="text-center py-16">
    <h1 class="text-5xl sm:text-7xl font-bold tracking-tight">
      Which Bean are You?
    </h1>
  </section>

  <section class="py-8 border-t border-stone-200 flex flex-col items-center">
    <ZodiacCalendar data={data} client:load />
  </section>
</Layout>

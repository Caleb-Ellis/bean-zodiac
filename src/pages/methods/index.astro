---
import { getCollection } from "astro:content";
import Layout from "../../layouts/Layout.astro";
import "../../styles/global.css";

import { METHOD_EMOJI, type MethodId } from "../../lib/zodiac";

const methods = await getCollection("methods");
---

<Layout
  title="The Four Methods"
  description="Fried, Roasted, Boiled, and Fermented - the four cooking methods that shape how you transform."
>
  <section class="py-12 text-center">
    <h1 class="text-4xl sm:text-5xl font-bold">The Four Methods</h1>
    <p class="mt-3 text-lg text-zinc-300 max-w-xl mx-auto">
      Each Bean is transformed by one of four Methods.
    </p>
  </section>
  <ul class="flex flex-col gap-3 list-none p-0 m-0 max-w-lg mx-auto w-full">
    {
      methods.map((method) => (
        <li class="rounded-xl border border-zinc-800 bg-zinc-900 overflow-hidden hover:border-zinc-600 transition-colors">
          <a href={`/methods/${method.id}`} class="flex no-underline">
            <div
              class={`w-14 shrink-0 bg-method-${method.id} flex items-center justify-center`}
            >
              <span style="filter: brightness(0); font-size: 1.5rem; line-height: 1;">
                {METHOD_EMOJI[method.id as MethodId]}
              </span>
            </div>
            <div class="p-4">
              <h2 class={`text-lg font-semibold method-${method.id}`}>
                {method.data.name}
              </h2>
              <p class="text-sm text-zinc-300 mt-0.5">{method.data.tagline}</p>
            </div>
          </a>
        </li>
      ))
    }
  </ul>
</Layout>

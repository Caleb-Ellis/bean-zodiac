---
import { getCollection } from "astro:content";
import Layout from "../../layouts/Layout.astro";
import "../../styles/global.css";

import { FLAVOUR_EMOJI, type FlavourId } from "../../lib/zodiac";

const flavours = await getCollection("flavours");
---

<Layout
  title="The Five Flavours"
  description="Bitter, Spicy, Umami, Sweet, and Sour - the five flavours that shape each Bean Zodiac year."
>
  <section class="py-12 text-center">
    <h1 class="text-4xl sm:text-5xl font-bold">The Five Flavours</h1>
    <p class="mt-3 text-lg text-zinc-300 max-w-xl mx-auto">
      Each year is shaped not only by its Bean, but by one of five fundamental
      Flavours.
    </p>
  </section>
  <ul class="flex flex-col gap-3 list-none p-0 m-0 max-w-lg mx-auto w-full">
    {
      flavours.map((flavour) => (
        <li class="rounded-xl border border-zinc-800 bg-zinc-900 overflow-hidden hover:border-zinc-600 transition-colors">
          <a href={`/flavours/${flavour.id}`} class="flex no-underline">
            <div class={`w-14 shrink-0 bg-flavour-${flavour.id} flex items-center justify-center`}>
              <span style="filter: brightness(0); font-size: 1.5rem; line-height: 1;">{FLAVOUR_EMOJI[flavour.id as FlavourId]}</span>
            </div>
            <div class="p-4">
              <h2 class={`text-lg font-semibold flavour-${flavour.id}`}>
                {flavour.data.name}
              </h2>
              <p class="text-sm text-zinc-300 mt-0.5">{flavour.data.tagline}</p>
            </div>
          </a>
        </li>
      ))
    }
  </ul>
</Layout>

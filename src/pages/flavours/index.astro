---
import { getCollection } from "astro:content";
import Layout from "../../layouts/Layout.astro";
import "../../styles/global.css";
import { FLAVOUR_ORDER } from "../../lib/zodiac";

const allFlavours = await getCollection("flavours");
const sortedFlavours = FLAVOUR_ORDER.map(
  (slug) => allFlavours.find((flavour) => flavour.id === slug)!,
);
---

<Layout
  title="The Five Flavours"
  description="Bitter, Spicy, Umami, Sweet, and Sour - the five flavours that shape each Bean Zodiac year."
>
  <section>
    <h1>The Five Flavours</h1>
    <p>
      Each year is shaped not only by its bean, but by one of five fundamental
      flavours.
    </p>
  </section>

  <ul>
    {
      sortedFlavours.map((flavour) => (
        <li>
          <a href={`/flavours/${flavour.id}`}>
            <h2 style={`color: ${flavour.data.color}`}>{flavour.data.name}</h2>
          </a>
          <p>{flavour.data.tagline}</p>
          <ul class="traits">
            {flavour.data.traits.map((trait) => (
              <li>{trait}</li>
            ))}
          </ul>
        </li>
      ))
    }
  </ul>
</Layout>

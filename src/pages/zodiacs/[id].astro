---
import { getCollection, getEntry, render } from "astro:content";
import Bean from "../../components/Bean.tsx";
import BeanBadge from "../../components/BeanBadge.tsx";
import FlavourBadge from "../../components/FlavourBadge.tsx";
import FormBadge from "../../components/FormBadge.tsx";
import TraitBadge from "../../components/TraitBadge.tsx";
import ZodiacDish from "../../components/ZodiacDish.tsx";
import ZodiacName from "../../components/ZodiacName.tsx";
import Layout from "../../layouts/Layout.astro";
import {
  getPreparationName,
  type BeanId,
  type FlavourId,
  type FormId,
} from "../../lib/zodiac";
import "../../styles/global.css";

export async function getStaticPaths() {
  const zodiacs = await getCollection("zodiacs");
  return zodiacs.map((zodiac) => ({
    params: { id: zodiac.id },
    props: { zodiac },
  }));
}

const { zodiac } = Astro.props;
const bean = await getEntry(zodiac.data.bean);
const flavour = await getEntry(zodiac.data.flavour);
const form = await getEntry(zodiac.data.form);
const beanId = bean.id as BeanId;
const flavourId = flavour.id as FlavourId;
const formId = form.id as FormId;
const preparation = getPreparationName(flavourId, formId);
const { Content: ZodiacContent } = await render(zodiac);
---

<Layout
  title={`${preparation} ${bean.data.name}`}
  description={zodiac.data.quote}
>
  <article
    class="rounded-2xl bg-zinc-900 border-2 border-zinc-800 overflow-hidden"
  >
    <div class="flex flex-col md:flex-row">
      <div class="w-full md:w-80 shrink-0 aspect-square">
        <Bean
          bean={bean.data}
          flavourId={flavourId}
          formId={formId}
          client:load
        />
      </div>
      <div class="p-6 md:p-8 flex flex-col gap-4 min-w-0">
        <a
          href="/"
          class="text-sm text-zinc-500 hover:text-zinc-300 transition-colors"
        >
          ← Home
        </a>
        <h1 class="text-3xl font-bold">
          <ZodiacName
            client:load
            flavourId={flavourId}
            formId={formId}
            beanId={beanId}
            preparation={preparation}
            beanName={bean.data.name}
          />
        </h1>
        <div class="flex flex-wrap items-center gap-2 text-sm text-zinc-400">
          <FlavourBadge client:load id={flavourId} name={flavour.data.name} />
          <span class="text-zinc-600">×</span>
          <FormBadge client:load id={formId} name={form.data.name} />
          <span class="text-zinc-600">×</span>
          <BeanBadge client:load id={beanId} name={bean.data.name} />
          <span class="text-zinc-600">=</span>
          <TraitBadge trait={zodiac.data.trait} featured />
        </div>
        <p class="text-zinc-300 italic">"{zodiac.data.quote}"</p>
        <div class="markdown-content mb-2">
          <ZodiacContent />
        </div>
        <ZodiacDish client:load dish={zodiac.data.dish} />
      </div>
    </div>
  </article>
</Layout>

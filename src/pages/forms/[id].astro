---
import { getCollection, render } from "astro:content";
import TraitBadge from "../../components/TraitBadge.tsx";
import Layout from "../../layouts/Layout.astro";
import "../../styles/global.css";

export async function getStaticPaths() {
  const forms = await getCollection("forms");
  return forms.map((form) => ({
    params: { id: form.id },
    props: { form },
  }));
}

import { FORM_EMOJI } from "../../lib/zodiac";

const { form } = Astro.props;
const { Content: FormContent } = await render(form);
---

<Layout
  title={`${form.data.name} Form`}
  description={`The ${form.data.name} Form of the Bean Zodiac`}
>
  <article
    class={`rounded-2xl bg-zinc-900 border-4 border-form-${form.id} overflow-hidden max-w-2xl mx-auto`}
  >
    <div class="flex flex-col md:flex-row">
      <div class="p-6 md:p-8 flex flex-col gap-4 min-w-0">
        <a
          href="/forms"
          class="text-sm text-zinc-500 hover:text-zinc-300 transition-colors"
        >
          ← All Forms
        </a>
        <h1
          class={`text-3xl font-bold form-${form.id} flex items-center gap-3`}
        >
          {form.data.name}
          <span style="font-size: 0.9em;"
            >{FORM_EMOJI[form.id as keyof typeof FORM_EMOJI]}</span
          >
        </h1>
        <ul class="flex flex-wrap gap-1.5 list-none p-0 m-0">
          {form.data.traits.map((trait) => <TraitBadge trait={trait} />)}
        </ul>
        <p class="text-zinc-300 italic">{form.data.tagline}</p>
        <div class="markdown-content">
          <FormContent />
        </div>
      </div>
    </div>
  </article>
</Layout>

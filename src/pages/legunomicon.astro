---
import { getCollection } from "astro:content";
import LegunomiconComponent from "../components/Legunomicon.tsx";
import Layout from "../layouts/Layout.astro";
import { buildAllZodiacData } from "../lib/data";
import "../styles/global.css";

const beanCollection = await getCollection("beans");
const flavourCollection = await getCollection("flavours");
const formCollection = await getCollection("forms");

const data = buildAllZodiacData(
  beanCollection,
  flavourCollection,
  formCollection,
);
---

<Layout title="The Legunomicon" description="Your Bean fortune history">
  <section class="flex flex-col items-center my-6 sm:my-12 px-4">
    <LegunomiconComponent data={data} client:load />
  </section>
</Layout>

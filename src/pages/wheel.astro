---
import { getCollection } from "astro:content";
import ZodiacWheelContainer from "../components/ZodiacWheelContainer";
import Layout from "../layouts/Layout.astro";
import { buildZodiacData } from "../lib/zodiac";
import "../styles/global.css";

const beanCollection = await getCollection("beans");
const flavourCollection = await getCollection("flavours");
const formCollection = await getCollection("forms");
const zodiacCollection = await getCollection("zodiacs");

const data = buildZodiacData(
  beanCollection,
  flavourCollection,
  formCollection,
  zodiacCollection,
);
---

<Layout
  title="Which Bean are You?"
  description="Pick a date and discover your inner Bean."
>
  <section class="text-center py-8">
    <h1 class="text-5xl sm:text-7xl font-bold tracking-tight">
      Consult the Wheel
    </h1>
  </section>
  <section class="border-zinc-800 flex flex-col items-center">
    <ZodiacWheelContainer data={data} client:load />
  </section>
</Layout>

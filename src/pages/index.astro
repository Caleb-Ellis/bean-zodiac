---
import { getEntry, render } from "astro:content";
import Layout from "../layouts/Layout.astro";
import BeanModel from "../components/BeanModel.astro";
import "../styles/global.css";
import { getCurrentZodiac } from "../lib/zodiac";

const zodiac = getCurrentZodiac();
const comboId = `${zodiac.bean}-${zodiac.element}`;

const [beanEntry, elementEntry, comboEntry] = await Promise.all([
	getEntry("beans", zodiac.bean),
	getEntry("elements", zodiac.element),
	getEntry("combos", comboId),
]);

if (!beanEntry || !elementEntry || !comboEntry) {
	throw new Error(
		`Missing content for zodiac: ${zodiac.bean} / ${zodiac.element}`,
	);
}

const { Content: ComboContent } = await render(comboEntry);
---

<Layout
  title="Bean Zodiac"
  description={`${beanEntry.data.name} + ${elementEntry.data.name} — ${comboEntry.data.tagline}`}
>
  <section class="hero">
    <p class="year-label">{zodiac.startDate} – {zodiac.endDate}</p>
    <h1>
      The Year of the<br />
      <span class="bean-name" style={`color: ${beanEntry.data.color}`}>
        {beanEntry.data.name}
      </span>
    </h1>
    <p class="flavour-label">
      <a
        href={`/elements/${zodiac.element}`}
        class="flavour-link"
        style={`color: ${elementEntry.data.color}`}
      >
        {elementEntry.data.name}
      </a>
    </p>
    <p class="tagline">{comboEntry.data.tagline}</p>
  </section>

  <section class="model-section">
    <BeanModel
      modelFile={beanEntry.data.modelFile}
      beanName={beanEntry.data.name}
      color={beanEntry.data.color}
    />
  </section>

  <section class="horoscope">
    <ComboContent />
  </section>

  <nav class="bottom-nav">
    <a href="/calendar">View the full calendar →</a>
    <a href={`/beans/${zodiac.bean}`}>About the {beanEntry.data.name} →</a>
    <a href={`/elements/${zodiac.element}`}>About the {elementEntry.data.name} flavour →</a>
  </nav>
</Layout>

---
import { getEntry, render } from "astro:content";
import Layout from "../layouts/Layout.astro";
import BeanModel from "../components/BeanModel.astro";
import "../styles/global.css";
import { getCurrentBeanZodiac } from "../lib/zodiac";

const currentBeanZodiac = getCurrentBeanZodiac();

const [beanEntry, flavourEntry, zodiacEntry] = await Promise.all([
  getEntry("beans", currentBeanZodiac.beanSlug),
  getEntry("flavours", currentBeanZodiac.flavourSlug),
  getEntry("zodiacs", currentBeanZodiac.slug),
]);

if (!beanEntry || !flavourEntry || !zodiacEntry) {
  throw new Error(`Missing content for zodiac: ${currentBeanZodiac.slug}`);
}
---

<Layout
  title="The Bean Zodiac"
  description={`${flavourEntry.data.name} + ${beanEntry.data.name}`}
>
  <section>
    <p>
      {currentBeanZodiac.startDate} - {currentBeanZodiac.endDate}
    </p>
    <h1>
      The Year of the
      <a
        href={`/flavours/${currentBeanZodiac.flavourSlug}`}
        style={`color: ${flavourEntry.data.color}`}
      >
        {flavourEntry.data.name}
      </a>
      <a
        href={`/beans/${currentBeanZodiac.beanSlug}`}
        style={`color: ${beanEntry.data.color}`}
      >
        {beanEntry.data.name}
      </a>
    </h1>
  </section>

  <section>
    <BeanModel
      modelFile={beanEntry.data.modelFile}
      beanName={beanEntry.data.name}
      color={beanEntry.data.color}
    />
  </section>

  <section>
    <p>{zodiacEntry.data.dish}</p>
    <p><strong>This Bean Year's fortune:</strong> {zodiacEntry.data.fortune}</p>
  </section>

  <nav>
    <a href="/calendar">View the full calendar →</a>
    <a href={`/beans/${currentBeanZodiac.beanSlug}`}
      >About the {beanEntry.data.name} →</a
    >
    <a href={`/flavours/${currentBeanZodiac.flavourSlug}`}
      >About the {flavourEntry.data.name} flavour →</a
    >
    <a href={`/zodiacs/${currentBeanZodiac.slug}`}
      >About those born in the Year of the {flavourEntry.data.name}
      {beanEntry.data.name} →</a
    >
  </nav>
</Layout>

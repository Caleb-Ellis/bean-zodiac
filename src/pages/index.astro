---
import { getCollection } from "astro:content";
import Layout from "../layouts/Layout.astro";
import "../styles/global.css";
import ZodiacResult from "../components/ZodiacResult";
import type { ZodiacData } from "../components/ZodiacDatePicker";
import { getCurrentBeanZodiac } from "../lib/zodiac";

const [allBeans, allFlavours, allZodiacs] = await Promise.all([
  getCollection("beans"),
  getCollection("flavours"),
  getCollection("zodiacs"),
]);

const data: ZodiacData = {
  beans: Object.fromEntries(
    allBeans.map((b) => [b.id, { name: b.data.name, color: b.data.color }]),
  ),
  flavours: Object.fromEntries(
    allFlavours.map((f) => [f.id, { name: f.data.name, color: f.data.color }]),
  ),
  zodiacs: Object.fromEntries(
    allZodiacs.map((z) => [z.id, { dish: z.data.dish, fortune: z.data.fortune, body: z.body ?? "" }]),
  ),
};

const currentZodiac = getCurrentBeanZodiac();
const currentBean = data.beans[currentZodiac.beanSlug];
const currentFlavour = data.flavours[currentZodiac.flavourSlug];
const currentEntry = data.zodiacs[currentZodiac.slug];
---

<Layout title="The Bean Zodiac" description="Find your bean.">
  <!-- Hero -->
  <section class="text-center py-16">
    <h1 class="text-5xl sm:text-7xl font-bold tracking-tight">The Bean Zodiac</h1>
    <p class="mt-3 text-xl sm:text-2xl text-stone-500">Discover your inner legume</p>
  </section>

  <!-- Current year zodiac (static) -->
  <section class="py-8 border-t border-stone-200 flex flex-col items-center">
    <ZodiacResult
      zodiac={currentZodiac}
      bean={currentBean}
      flavour={currentFlavour}
      entry={currentEntry}
      client:load
    />
  </section>
</Layout>

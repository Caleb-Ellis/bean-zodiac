---
import { getCollection } from "astro:content";
import Layout from "../layouts/Layout.astro";
import "../styles/global.css";
import ZodiacDatePicker from "../components/ZodiacDatePicker";
import type { ZodiacData } from "../components/ZodiacDatePicker";
import { BEAN_ORDER } from "../lib/zodiac";

const [allBeans, allFlavours, allZodiacs] = await Promise.all([
  getCollection("beans"),
  getCollection("flavours"),
  getCollection("zodiacs"),
]);

const data: ZodiacData = {
  beans: Object.fromEntries(
    allBeans.map((b) => [b.id, { name: b.data.name, color: b.data.color }]),
  ),
  flavours: Object.fromEntries(
    allFlavours.map((f) => [f.id, { name: f.data.name, color: f.data.color }]),
  ),
  zodiacs: Object.fromEntries(
    allZodiacs.map((z) => [z.id, { dish: z.data.dish, fortune: z.data.fortune }]),
  ),
};

const sortedBeans = BEAN_ORDER.map(
  (slug) => allBeans.find((b) => b.id === slug)!,
);
---

<Layout title="The Bean Zodiac" description="Find your bean.">
  <!-- Hero -->
  <section class="text-center py-16">
    <h1 class="text-5xl sm:text-7xl font-bold tracking-tight">The Bean Zodiac</h1>
    <p class="mt-3 text-xl sm:text-2xl text-stone-500">Discover your inner legume</p>
  </section>

  <!-- Date picker -->
  <section class="py-8 border-t border-stone-200 flex flex-col items-center">
    <ZodiacDatePicker data={data} client:load />
  </section>

  <!-- Zodiac wheel placeholder -->
  <section class="py-16 border-t border-stone-200 flex flex-col items-center gap-6">
    <div class="relative w-72 h-72 sm:w-96 sm:h-96">
      <!-- Outer dashed ring -->
      <div class="absolute inset-0 rounded-full border-4 border-dashed border-stone-200"></div>
      <!-- 12 bean dots positioned around the ring -->
      {
        sortedBeans.map((bean, i) => {
          const angle = (i / 12) * 360 - 90; // start from top
          const rad = (angle * Math.PI) / 180;
          const r = 44; // percent radius from center
          const x = 50 + r * Math.cos(rad);
          const y = 50 + r * Math.sin(rad);
          return (
            <a
              href={`/beans/${bean.id}`}
              title={bean.data.name}
              style={`left: ${x}%; top: ${y}%; background-color: ${bean.data.color}`}
              class="absolute w-4 h-4 sm:w-5 sm:h-5 rounded-full -translate-x-1/2 -translate-y-1/2 hover:scale-125 transition-transform"
            />
          );
        })
      }
      <!-- Center label -->
      <div class="absolute inset-0 flex items-center justify-center">
        <span class="text-stone-400 text-xs sm:text-sm text-center leading-snug">
          Zodiac Wheel<br />Coming Soon
        </span>
      </div>
    </div>
  </section>
</Layout>

---
import { getCollection } from "astro:content";
import ZodiacResult from "../components/ZodiacResult.tsx";
import Layout from "../layouts/Layout.astro";
import { buildZodiacData } from "../lib/zodiac";
import "../styles/global.css";

const beanCollection = await getCollection("beans");
const flavourCollection = await getCollection("flavours");
const formCollection = await getCollection("forms");
const zodiacCollection = await getCollection("zodiacs");

const data = buildZodiacData(
  beanCollection,
  flavourCollection,
  formCollection,
  zodiacCollection,
);
---

<Layout title="The Bean Zodiac" description="Discover your inner legume">
  <section class="flex flex-col items-center my-6 sm:my-12">
    <ZodiacResult data={data} date={new Date()} showFortune client:load />
  </section>
  <section class="flex flex-col items-center my-8">
    <a
      class="bg-zinc-900/80 border border-zinc-500/60 text-white rounded-xl px-8 py-4 font-bold backdrop-blur-sm transition-all duration-200 hover:border-zinc-400 hover:text-white hover:bg-zinc-800/80 cursor-pointer"
      href="/calendar">Which Bean are You?&nbsp;→</a
    >
  </section>
</Layout>

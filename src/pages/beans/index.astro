---
import { getCollection } from "astro:content";
import Layout from "../../layouts/Layout.astro";
import BeanModel from "../../components/BeanModel.astro";
import "../../styles/global.css";
import { BEAN_ORDER } from "../../lib/zodiac";

const allBeans = await getCollection("beans");
const sortedBeans = BEAN_ORDER.map(
  (slug) => allBeans.find((bean) => bean.id === slug)!,
);
---

<Layout
  title="The Twelve Beans"
  description="The twelve bean varieties of the Bean Zodiac, each with its own character, fortune, and wisdom."
>
  <section>
    <h1>The Twelve Beans</h1>
    <p>
      Each bean carries its own character, wisdom, and fortune. Which one are
      you?
    </p>
  </section>

  <ul>
    {
      sortedBeans.map((bean) => (
        <li>
          <a href={`/beans/${bean.id}`}>
            <BeanModel
              beanName={bean.data.name}
              color={bean.data.color}
              modelFile={bean.data.modelFile}
            />
            <h2 style={`color: ${bean.data.color}`}>{bean.data.name}</h2>
          </a>
          <p>{bean.data.tagline}</p>
          <ul class="traits">
            {bean.data.traits.map((trait) => (
              <li>{trait}</li>
            ))}
          </ul>
        </li>
      ))
    }
  </ul>
</Layout>

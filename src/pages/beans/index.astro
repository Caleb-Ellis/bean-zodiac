---
import { getCollection } from "astro:content";
import Bean from "../../components/Bean.tsx";
import Layout from "../../layouts/Layout.astro";
import "../../styles/global.css";

const beans = await getCollection("beans");
---

<Layout
  title="The Twelve Beans"
  description="The twelve bean varieties of the Bean Zodiac, each with its own character, fortune, and wisdom."
>
  <section class="py-12 text-center">
    <h1 class="text-4xl sm:text-5xl font-bold">The Twelve Beans</h1>
    <p class="mt-4 text-lg text-zinc-300 max-w-xl mx-auto">
      Each Bean carries its own character, wisdom, and fortune.
    </p>
    <p class="flex flex-col items-center mt-2 sm:mt-4">
      <a class="link text-xl font-bold" href="/calendar"
        >Which Bean are you?&nbsp;→</a
      >
    </p>
  </section>
  <ul
    class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6 list-none p-0 m-0"
  >
    {
      beans.map((bean) => (
        <li class="rounded-2xl border border-zinc-800 bg-zinc-900 overflow-hidden hover:border-zinc-600 transition-colors">
          <a href={`/beans/${bean.id}`} class="block aspect-square w-full">
            <Bean bean={bean.data} />
          </a>
          <div class="p-4">
            <h2 class={`text-lg font-semibold bean-${bean.id}`}>
              {bean.data.name}
            </h2>
            <p class="text-sm text-zinc-300 mt-1">{bean.data.tagline}</p>
            <ul class="flex flex-wrap gap-1.5 mt-3 list-none p-0 m-0">
              {bean.data.traits.map((trait) => (
                <li class="text-xs px-2.5 py-1 rounded-full bg-zinc-800 text-zinc-300">
                  {trait}
                </li>
              ))}
            </ul>
          </div>
        </li>
      ))
    }
  </ul>
</Layout>

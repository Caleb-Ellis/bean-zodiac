---
import type { BeanSchema } from '../schemas';

/**
 * BeanModel — placeholder for a future Three.js / WebGL bean renderer.
 *
 * When 3D models are ready:
 * 1. Install a Three.js integration (e.g. threlte or vanilla three)
 * 2. Drop .glb files into public/models/
 * 3. Replace the placeholder below with the actual canvas/scene component
 */

type Props = {
  bean: BeanSchema
}

const { bean } = Astro.props;
const { color, name, modelFile } = bean
---

<div
  class="bean-model"
  style={`--bean-color: ${color}`}
  aria-label={`3D model of ${name}`}
>
  {modelFile ? (
    <!-- TODO: replace with Three.js canvas. Model: /models/{modelFile} -->
    <div class="placeholder">
      <span class="bean-dot" />
    </div>
  ) : (
    <div class="placeholder">
      <span class="bean-dot" />
    </div>
  )}
  <p class="sr-only">{name}</p>
</div>

<style>
  .bean-model {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    height: 100%;
  }

  .placeholder {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    height: 100%;
  }

  .bean-dot {
    display: block;
    width: 80px;
    height: 60px;
    border-radius: 50% 50% 50% 50% / 60% 60% 40% 40%;
    background-color: var(--bean-color);
  }

  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    overflow: hidden;
    clip: rect(0 0 0 0);
  }
</style>

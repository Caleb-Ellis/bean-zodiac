  .orb-5 {
    width: 620px;
    height: 620px;
    background: radial-gradient(
      circle,
      rgba(59, 130, 246, 0.8) 0%,
      rgba(59, 130, 246, 0.2) 40%,
      transparent 70%
    );
    top: 5%;
    right: 15%;
    animation-duration: 61s;

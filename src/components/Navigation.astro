---
const links = [
  { href: "/beans", label: "Meet the Beans", short: "Beans" },
  { href: "/flavours", label: "Taste the Flavours", short: "Flavours" },
  { href: "/forms", label: "Become the Forms", short: "Forms" },
  {
    href: "/compatibility",
    label: "Bean Compatibility",
    short: "Compatibility",
  },
];

const current = Astro.url.pathname;
---

<nav
  class="flex flex-wrap items-center justify-between px-4 sm:px-6 py-4 border-b border-zinc-800 bg-zinc-950 gap-x-4 gap-y-3 sm:gap-x-6"
>
  <a
    href="/"
    class="link font-bold text-center inline-flex items-center sm:text-left"
  >
    The Bean Zodiac
  </a>
  <a href="/calendar" class="font-bold md:hidden">Which Bean are You?</a>
  <ul class="flex gap-4 sm:gap-6 list-none m-0 p-0">
    {
      links.map(({ href, label, short }) => {
        return (
          <li>
            <a
              href={href}
              class:list={[
                "link text-sm sm:text-base text-center inline-flex items-center sm:text-left",
                {
                  active: current.startsWith(href),
                  "font-bold": current.startsWith(href) || href === "/calendar",
                },
              ]}
            >
              <span class="md:hidden">{short}</span>
              <span class="hidden md:inline">{label}</span>
            </a>
          </li>
        );
      })
    }
    <li>
      <a
        href="/calendar"
        class="link text-sm md:text-base text-center items-center md:text-left font-bold hidden md:inline-flex"
      >
        Which Bean are You?
      </a>
    </li>
  </ul>
</nav>

---
const links = [
  { href: "/beans", label: "Meet the Beans", short: "Beans" },
  { href: "/flavours", label: "Taste the Flavours", short: "Flavours" },
  { href: "/forms", label: "Become the Forms", short: "Forms" },
  {
    href: "/compatibility",
    label: "Match Beans",
    short: "Compatibility",
  },
];

const current = Astro.url.pathname;
---

<nav
  class="flex items-center justify-between px-4 sm:px-6 py-4 border-b-2 border-zinc-800 bg-zinc-950"
>
  <a href="/" class="link font-bold inline-flex items-center gap-2">
    <span style="filter: brightness(0) invert(1)">🫘</span> The Bean Zodiac
  </a>
  <ul class="hidden md:flex gap-6 list-none m-0 p-0">
    {
      links.map(({ href, label }) => {
        return (
          <li>
            <a
              href={href}
              class:list={[
                "link text-base",
                { active: current.startsWith(href) },
              ]}
            >
              {label}
            </a>
          </li>
        );
      })
    }
    <li>
      <a
        href="/wheel"
        class:list={["link font-bold", { active: current === "/wheel" }]}
      >
        The Wheel of Beans
      </a>
    </li>
  </ul>
</nav>

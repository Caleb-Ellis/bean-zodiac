---
const links = [
	{ href: "/", label: "This Year" },
	{ href: "/calendar", label: "Calendar" },
	{ href: "/beans", label: "Beans" },
	{ href: "/elements", label: "Elements" },
];

const current = Astro.url.pathname;
---

<nav>
  <a href="/" class="nav-logo">Bean Zodiac</a>
  <ul>
    {links.map(({ href, label }) => (
      <li>
        <a href={href} class:list={[{ active: current === href }]}>{label}</a>
      </li>
    ))}
  </ul>
</nav>

<style>
  nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 1rem 2rem;
    border-bottom: 1px solid currentColor;
  }

  .nav-logo {
    font-weight: 700;
    text-decoration: none;
  }

  ul {
    display: flex;
    gap: 1.5rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  a {
    text-decoration: none;
  }

  a.active {
    text-decoration: underline;
  }
</style>

---
const links = [
  { href: "/beans", label: "Meet the Beans" },
  { href: "/flavours", label: "Taste the Flavours" },
  { href: "/calendar", label: "Which Bean are You?" },
];

const current = Astro.url.pathname;
---

<nav
  class="flex items-center justify-between px-4 sm:px-6 py-4 border-b border-zinc-800 bg-zinc-950 gap-4 sm:gap-6"
>
  <a
    href="/"
    class="link font-bold text-center inline-flex items-center sm:text-left"
  >
    The Bean Zodiac
  </a>
  <ul class="flex gap-4 sm:gap-6 list-none m-0 p-0">
    {
      links.map(({ href, label }) => (
        <li>
          <a
            href={href}
            class:list={[
              "link text-sm sm:text-base text-center inline-flex items-center sm:text-left",
              { "active font-medium": current.startsWith(href) },
            ]}
          >
            {label}
          </a>
        </li>
      ))
    }
  </ul>
</nav>

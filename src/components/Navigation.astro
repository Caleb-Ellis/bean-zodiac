---
const links = [
  { href: "/beans", label: "Meet the Beans" },
  { href: "/flavours", label: "Taste the Flavours" },
  { href: "/calendar", label: "Which Bean are You?" },
];

const current = Astro.url.pathname;
---

<nav
  class="flex items-center justify-between px-4 sm:px-6 py-4 border-b border-zinc-800 bg-zinc-950"
>
  <a
    href="/"
    class="font-bold text-white no-underline hover:opacity-75 transition-opacity"
  >
    The Bean Zodiac
  </a>
  <ul class="flex gap-4 sm:gap-6 list-none m-0 p-0">
    {
      links.map(({ href, label }) => (
        <li>
          <a
            href={href}
            class:list={[
              "text-zinc-300 no-underline hover:text-white transition-colors text-sm sm:text-base",
              {
                "underline underline-offset-4 font-medium":
                  current.startsWith(href),
              },
            ]}
          >
            {label}
          </a>
        </li>
      ))
    }
  </ul>
</nav>

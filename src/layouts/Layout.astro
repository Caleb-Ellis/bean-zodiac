---
import { ClientRouter } from "astro:transitions";
import Navigation from "../components/Navigation.astro";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "The Bean Zodiac",
  description = "Discover your Bean Zodiac and what the stars — and legumes — have in store.",
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <title>
      {title === "The Bean Zodiac" ? title : `${title} — The Bean Zodiac`}
    </title>
  </head>
  <body class="bg-zinc-950 text-white min-h-screen font-sans">
    <div class="orbs" aria-hidden="true">
      <div class="orb orb-1"></div>
      <div class="orb orb-2"></div>
      <div class="orb orb-3"></div>
      <div class="orb orb-4"></div>
      <div class="orb orb-5"></div>
    </div>
    <div class="relative z-10">
      <Navigation />
      <main class="max-w-6xl mx-auto px-4 sm:px-6 py-8 animate-fade-up">
        <slot />
      </main>
    </div>
  </body>
</html>

<style>
  html,
  body {
    margin: 0;
    width: 100%;
    height: 100%;
  }

  .orbs {
    position: fixed;
    inset: 0;
    overflow: hidden;
    pointer-events: none;
    z-index: 0;
  }

  .orb {
    position: absolute;
    border-radius: 50%;
    filter: blur(80px);
    opacity: 0.4;
    animation: drift linear infinite;
  }

  .orb-1 {
    width: 520px;
    height: 520px;
    background: radial-gradient(circle, #a855f7, transparent 70%);
    top: -10%;
    left: -5%;
    animation-duration: 38s;
    animation-name: drift-1;
  }

  .orb-2 {
    width: 420px;
    height: 420px;
    background: radial-gradient(circle, #ef4444, transparent 70%);
    top: 30%;
    right: -8%;
    animation-duration: 47s;
    animation-name: drift-2;
  }

  .orb-3 {
    width: 380px;
    height: 380px;
    background: radial-gradient(circle, #22c55e, transparent 70%);
    bottom: -5%;
    left: 20%;
    animation-duration: 55s;
    animation-name: drift-3;
  }

  .orb-4 {
    width: 300px;
    height: 300px;
    background: radial-gradient(circle, #f59e0b, transparent 70%);
    top: 55%;
    left: -3%;
    animation-duration: 42s;
    animation-name: drift-4;
  }

  .orb-5 {
    width: 460px;
    height: 460px;
    background: radial-gradient(circle, #3b82f6, transparent 70%);
    top: 10%;
    right: 20%;
    animation-duration: 61s;
    animation-name: drift-5;
  }

  @keyframes drift-1 {
    0% {
      transform: translate(0, 0) scale(1);
    }
    25% {
      transform: translate(8vw, 12vh) scale(1.12);
    }
    50% {
      transform: translate(4vw, 22vh) scale(0.92);
    }
    75% {
      transform: translate(-4vw, 10vh) scale(1.08);
    }
    100% {
      transform: translate(0, 0) scale(1);
    }
  }

  @keyframes drift-2 {
    0% {
      transform: translate(0, 0) scale(1);
    }
    33% {
      transform: translate(-10vw, 8vh) scale(1.1);
    }
    66% {
      transform: translate(-6vw, -12vh) scale(0.88);
    }
    100% {
      transform: translate(0, 0) scale(1);
    }
  }

  @keyframes drift-3 {
    0% {
      transform: translate(0, 0) scale(1);
    }
    30% {
      transform: translate(6vw, -10vh) scale(1.15);
    }
    60% {
      transform: translate(-8vw, -6vh) scale(0.9);
    }
    100% {
      transform: translate(0, 0) scale(1);
    }
  }

  @keyframes drift-4 {
    0% {
      transform: translate(0, 0) scale(1);
    }
    40% {
      transform: translate(12vw, -8vh) scale(1.2);
    }
    70% {
      transform: translate(8vw, 6vh) scale(0.85);
    }
    100% {
      transform: translate(0, 0) scale(1);
    }
  }

  @keyframes drift-5 {
    0% {
      transform: translate(0, 0) scale(1);
    }
    20% {
      transform: translate(-5vw, 10vh) scale(0.9);
    }
    55% {
      transform: translate(-12vw, 5vh) scale(1.18);
    }
    80% {
      transform: translate(-4vw, -8vh) scale(1.05);
    }
    100% {
      transform: translate(0, 0) scale(1);
    }
  }
</style>

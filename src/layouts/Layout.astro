---
import Navigation from "../components/Navigation.astro";
import BottomTabBar from "../components/BottomTabBar.astro";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "The Bean Zodiac",
  description = "Discover your Bean Zodiac and what the stars — and legumes — have in store.",
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, viewport-fit=cover" />
    <link
      rel="icon"
      href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 100 100%22><defs><filter id=%22w%22><feComponentTransfer><feFuncR type=%22linear%22 slope=%220%22 intercept=%221%22/><feFuncG type=%22linear%22 slope=%220%22 intercept=%221%22/><feFuncB type=%22linear%22 slope=%220%22 intercept=%221%22/></feComponentTransfer></filter></defs><text y=%22.9em%22 font-size=%2290%22 filter=%22url(%23w)%22>🫘</text></svg>"
    />
    <meta name="generator" content={Astro.generator} />
    <link rel="preload" as="image" href="/images/adzuki.svg" />
    <link rel="preload" as="image" href="/images/adzuki.webp" />
    <link rel="preload" as="image" href="/images/black.svg" />
    <link rel="preload" as="image" href="/images/black.webp" />
    <link rel="preload" as="image" href="/images/butter.svg" />
    <link rel="preload" as="image" href="/images/butter.webp" />
    <link rel="preload" as="image" href="/images/cannellini.svg" />
    <link rel="preload" as="image" href="/images/cannellini.webp" />
    <link rel="preload" as="image" href="/images/chickpea.svg" />
    <link rel="preload" as="image" href="/images/chickpea.webp" />
    <link rel="preload" as="image" href="/images/edamame.svg" />
    <link rel="preload" as="image" href="/images/edamame.webp" />
    <link rel="preload" as="image" href="/images/fava.svg" />
    <link rel="preload" as="image" href="/images/fava.webp" />
    <link rel="preload" as="image" href="/images/green.svg" />
    <link rel="preload" as="image" href="/images/green.webp" />
    <link rel="preload" as="image" href="/images/kidney.svg" />
    <link rel="preload" as="image" href="/images/kidney.webp" />
    <link rel="preload" as="image" href="/images/mung.svg" />
    <link rel="preload" as="image" href="/images/mung.webp" />
    <link rel="preload" as="image" href="/images/navy.svg" />
    <link rel="preload" as="image" href="/images/navy.webp" />
    <link rel="preload" as="image" href="/images/pinto.svg" />
    <link rel="preload" as="image" href="/images/pinto.webp" />
    <meta name="description" content={description} />
    <title>
      {title === "The Bean Zodiac" ? title : `${title} — The Bean Zodiac`}
    </title>
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="The Bean Zodiac" />
    <meta
      property="og:title"
      content={title === "The Bean Zodiac"
        ? title
        : `${title} — The Bean Zodiac`}
    />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={new URL("/og.png", Astro.site).href} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta
      name="twitter:title"
      content={title === "The Bean Zodiac"
        ? title
        : `${title} — The Bean Zodiac`}
    />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={new URL("/og.png", Astro.site).href} />
  </head>
  <body class="bg-zinc-950 text-white min-h-screen font-sans">
    <!--
      Edge-only form filters. Each shares the same 6-step pipeline:
        1. feColorMatrix  — colour-shift the full image → colorized
        2. feComponentTransfer — adjust per-channel gamma → colorized
        3. feMorphology erode SourceAlpha → eroded (alpha shrunk inward)
        4. feComposite SourceAlpha out eroded → edgeHard (ring at boundary)
        5. feGaussianBlur edgeHard → edgeMask (soft gradient fade inward)
        6. feComposite colorized in edgeMask → colorizedEdge (effect at edges only)
        7. feComposite colorizedEdge over SourceGraphic → original interior + coloured edges
    -->
    <svg style="display: none" xmlns="http://www.w3.org/2000/svg">
      <defs>
        <filter id="form-roasted-filter" color-interpolation-filters="sRGB">
          <!-- Subtle overall warm-dark tint applied to the whole bean -->
          <feColorMatrix
            in="SourceGraphic"
            type="matrix"
            result="baseTinted"
            values="1.04 0 0 0 0.01  0 0.95 0 0 0  0 0 0.78 0 0  0 0 0 1 0"
          ></feColorMatrix>
          <!-- Heat crackle — soft fractalNoise for faint surface variation, not harsh grime -->
          <feTurbulence
            type="fractalNoise"
            baseFrequency="0.08"
            numOctaves="2"
            seed="42"
            result="crackNoise"></feTurbulence>
          <feGaussianBlur in="crackNoise" stdDeviation="1.5" result="crackNoise"
          ></feGaussianBlur>
          <feColorMatrix
            in="crackNoise"
            type="saturate"
            values="0"
            result="crackNoise"></feColorMatrix>
          <feComponentTransfer in="crackNoise" result="crackle">
            <feFuncR type="linear" slope="0.10" intercept="0.90"></feFuncR>
            <feFuncG type="linear" slope="0.10" intercept="0.90"></feFuncG>
            <feFuncB type="linear" slope="0.10" intercept="0.90"></feFuncB>
          </feComponentTransfer>
          <feComposite
            in="crackle"
            in2="SourceAlpha"
            operator="in"
            result="clippedCrackle"></feComposite>
          <feBlend
            in="baseTinted"
            in2="clippedCrackle"
            mode="multiply"
            result="baseTinted"></feBlend>
          <!-- Ring 1: wide dark-orange that blurs inward -->
          <feColorMatrix
            in="SourceGraphic"
            type="matrix"
            result="brownColorized"
            values="0.65 0.20 0.03 0 0  0.15 0.48 0.03 0 0.02  0.02 0.03 0.12 0 0  0 0 0 1 0"
          ></feColorMatrix>
          <feComponentTransfer in="brownColorized" result="brownColorized">
            <feFuncR type="gamma" amplitude="1" exponent="1.3" offset="0"
            ></feFuncR>
            <feFuncG type="gamma" amplitude="1" exponent="1.4" offset="0"
            ></feFuncG>
            <feFuncB type="gamma" amplitude="1" exponent="1.6" offset="0"
            ></feFuncB>
          </feComponentTransfer>
          <feMorphology
            in="SourceAlpha"
            operator="erode"
            radius="10"
            result="brownEroded"></feMorphology>
          <feComposite
            in="SourceAlpha"
            in2="brownEroded"
            operator="out"
            result="brownEdgeHard"></feComposite>
          <feGaussianBlur
            in="brownEdgeHard"
            stdDeviation="10"
            result="brownEdgeMask"></feGaussianBlur>
          <feComposite
            in="brownColorized"
            in2="brownEdgeMask"
            operator="in"
            result="brownEdge"></feComposite>
          <!-- Ring 2: thin dark crust right at the boundary, slightly blurred -->
          <feColorMatrix
            in="SourceGraphic"
            type="matrix"
            result="blackColorized"
            values="0.22 0.07 0.01 0 0  0.07 0.16 0.01 0 0  0.01 0.02 0.10 0 0  0 0 0 1 0"
          ></feColorMatrix>
          <feMorphology
            in="SourceAlpha"
            operator="erode"
            radius="2"
            result="blackEroded"></feMorphology>
          <feComposite
            in="SourceAlpha"
            in2="blackEroded"
            operator="out"
            result="blackEdgeHard"></feComposite>
          <feGaussianBlur
            in="blackEdgeHard"
            stdDeviation="6"
            result="blackEdgeMask"></feGaussianBlur>
          <feComposite
            in="blackColorized"
            in2="blackEdgeMask"
            operator="in"
            result="blackEdge"></feComposite>
          <!-- Composite: brown ring over base, then black ring on top -->
          <feComposite
            in="brownEdge"
            in2="baseTinted"
            operator="over"
            result="withBrown"></feComposite>
          <feComposite in="blackEdge" in2="withBrown" operator="over"
          ></feComposite>
        </filter>

        <filter id="form-fried-filter" color-interpolation-filters="sRGB">
          <!-- Subtle overall warm-red tint applied to the whole bean -->
          <feColorMatrix
            in="SourceGraphic"
            type="matrix"
            result="baseTinted"
            values="1.05 0 0 0 0.01  0 0.99 0 0 0  0 0 0.88 0 0  0 0 0 1 0"
          ></feColorMatrix>
          <!-- Sizzle mottling — medium-freq fractalNoise blurred slightly to soften harsh grain into gentle sear mottling -->
          <feTurbulence
            type="fractalNoise"
            baseFrequency="0.30"
            numOctaves="2"
            seed="8"
            result="sizzleNoise"></feTurbulence>
          <feGaussianBlur
            in="sizzleNoise"
            stdDeviation="1.5"
            result="sizzleNoise"></feGaussianBlur>
          <feColorMatrix
            in="sizzleNoise"
            type="saturate"
            values="0"
            result="sizzleNoise"></feColorMatrix>
          <feComponentTransfer in="sizzleNoise" result="sizzleNoise">
            <feFuncR type="linear" slope="0.14" intercept="0.86"></feFuncR>
            <feFuncG type="linear" slope="0.14" intercept="0.86"></feFuncG>
            <feFuncB type="linear" slope="0.14" intercept="0.86"></feFuncB>
          </feComponentTransfer>
          <feComposite
            in="sizzleNoise"
            in2="SourceAlpha"
            operator="in"
            result="clippedSizzle"></feComposite>
          <feBlend
            in="baseTinted"
            in2="clippedSizzle"
            mode="multiply"
            result="baseTinted"></feBlend>
          <!-- Stronger red-yellow shift for the edge crust, applied to SourceGraphic -->
          <feColorMatrix
            in="SourceGraphic"
            type="matrix"
            result="colorized"
            values="1.12 0.06 0 0 0.02  0.03 0.90 0.02 0 0  0 0 0.55 0 0  0 0 0 1 0"
          ></feColorMatrix>
          <feComponentTransfer in="colorized" result="colorized">
            <feFuncR type="gamma" amplitude="1" exponent="0.90" offset="0"
            ></feFuncR>
            <feFuncG type="gamma" amplitude="1" exponent="1.10" offset="0"
            ></feFuncG>
            <feFuncB type="gamma" amplitude="1" exponent="1.25" offset="0"
            ></feFuncB>
          </feComponentTransfer>
          <!-- Narrower, softer edge mask for a more subtle crust ring -->
          <feMorphology
            in="SourceAlpha"
            operator="erode"
            radius="4"
            result="eroded"></feMorphology>
          <feComposite
            in="SourceAlpha"
            in2="eroded"
            operator="out"
            result="edgeHard"></feComposite>
          <feGaussianBlur in="edgeHard" stdDeviation="4" result="edgeMask"
          ></feGaussianBlur>
          <feComposite
            in="colorized"
            in2="edgeMask"
            operator="in"
            result="colorizedEdge"></feComposite>
          <!-- Very thin blurred dark outer ring -->
          <feColorMatrix
            in="SourceGraphic"
            type="matrix"
            result="blackColorized"
            values="0.35 0.08 0.01 0 0  0.05 0.12 0.01 0 0  0.01 0.02 0.06 0 0  0 0 0 1 0"
          ></feColorMatrix>
          <feMorphology
            in="SourceAlpha"
            operator="erode"
            radius="1"
            result="blackEroded"></feMorphology>
          <feComposite
            in="SourceAlpha"
            in2="blackEroded"
            operator="out"
            result="blackEdgeHard"></feComposite>
          <feGaussianBlur
            in="blackEdgeHard"
            stdDeviation="2"
            result="blackEdgeMask"></feGaussianBlur>
          <feComposite
            in="blackColorized"
            in2="blackEdgeMask"
            operator="in"
            result="blackEdge"></feComposite>
          <!-- Layer: colorized edge over base, then dark ring on top -->
          <feComposite
            in="colorizedEdge"
            in2="baseTinted"
            operator="over"
            result="withEdge"></feComposite>
          <feComposite in="blackEdge" in2="withEdge" operator="over"
          ></feComposite>
        </filter>

        <filter id="form-boiled-filter" color-interpolation-filters="sRGB">
          <feColorMatrix
            in="SourceGraphic"
            type="matrix"
            result="colorized"
            values="0.70 0.10 0.05 0 0.07  0.05 0.72 0.08 0 0.05  0.05 0.10 0.85 0 0.05  0 0 0 1 0"
          ></feColorMatrix>
          <feComponentTransfer in="colorized" result="colorized">
            <feFuncR type="gamma" amplitude="1" exponent="0.7" offset="0"
            ></feFuncR>
            <feFuncG type="gamma" amplitude="1" exponent="0.7" offset="0"
            ></feFuncG>
            <feFuncB type="gamma" amplitude="1" exponent="0.7" offset="0"
            ></feFuncB>
          </feComponentTransfer>
          <feMorphology
            in="SourceAlpha"
            operator="erode"
            radius="10"
            result="eroded"></feMorphology>
          <feComposite
            in="SourceAlpha"
            in2="eroded"
            operator="out"
            result="edgeHard"></feComposite>
          <feGaussianBlur in="edgeHard" stdDeviation="6" result="edgeMask"
          ></feGaussianBlur>
          <feComposite
            in="colorized"
            in2="edgeMask"
            operator="in"
            result="colorizedEdge"></feComposite>
          <feComposite in="colorizedEdge" in2="SourceGraphic" operator="over"
          ></feComposite>
        </filter>

        <filter id="form-fermented-filter" color-interpolation-filters="sRGB">
          <!-- Subtle green base tint on the whole bean -->
          <feColorMatrix
            in="SourceGraphic"
            type="matrix"
            result="baseTinted"
            values="0.99 0 0 0 0  0 1.01 0 0 0  0 0 0.96 0 0  0 0 0 1 0"
          ></feColorMatrix>
          <!-- Blotchy mottling — low-freq noise for uneven fermentation cultures and dark patches -->
          <feTurbulence
            type="fractalNoise"
            baseFrequency="0.06"
            numOctaves="2"
            seed="23"
            result="cultureMold"></feTurbulence>
          <feColorMatrix
            in="cultureMold"
            type="saturate"
            values="0"
            result="cultureMold"></feColorMatrix>
          <feComponentTransfer in="cultureMold" result="cultureMold">
            <feFuncR type="linear" slope="0.18" intercept="0.82"></feFuncR>
            <feFuncG type="linear" slope="0.18" intercept="0.82"></feFuncG>
            <feFuncB type="linear" slope="0.18" intercept="0.82"></feFuncB>
          </feComponentTransfer>
          <feComposite
            in="cultureMold"
            in2="SourceAlpha"
            operator="in"
            result="clippedMold"></feComposite>
          <feBlend
            in="baseTinted"
            in2="clippedMold"
            mode="multiply"
            result="baseTinted"></feBlend>
          <!-- Ring 1: wide dark-green that blurs inward -->
          <feColorMatrix
            in="SourceGraphic"
            type="matrix"
            result="greenColorized"
            values="0.65 0.06 0.02 0 0  0.05 0.68 0.05 0 0  0.02 0.04 0.52 0 0  0 0 0 1 0"
          ></feColorMatrix>
          <feComponentTransfer in="greenColorized" result="greenColorized">
            <feFuncR type="gamma" amplitude="1" exponent="1.15" offset="0"
            ></feFuncR>
            <feFuncG type="gamma" amplitude="1" exponent="1.10" offset="0"
            ></feFuncG>
            <feFuncB type="gamma" amplitude="1" exponent="1.20" offset="0"
            ></feFuncB>
          </feComponentTransfer>
          <feMorphology
            in="SourceAlpha"
            operator="erode"
            radius="10"
            result="greenEroded"></feMorphology>
          <feComposite
            in="SourceAlpha"
            in2="greenEroded"
            operator="out"
            result="greenEdgeHard"></feComposite>
          <feGaussianBlur
            in="greenEdgeHard"
            stdDeviation="10"
            result="greenEdgeMask"></feGaussianBlur>
          <feComposite
            in="greenColorized"
            in2="greenEdgeMask"
            operator="in"
            result="greenEdge"></feComposite>
          <!-- Ring 2: outer brown-green crust, diffused -->
          <feColorMatrix
            in="SourceGraphic"
            type="matrix"
            result="brownColorized"
            values="0.62 0.08 0.01 0 0  0.05 0.58 0.01 0 0  0.01 0.02 0.38 0 0  0 0 0 1 0"
          ></feColorMatrix>
          <feMorphology
            in="SourceAlpha"
            operator="erode"
            radius="2"
            result="brownEroded"></feMorphology>
          <feComposite
            in="SourceAlpha"
            in2="brownEroded"
            operator="out"
            result="brownEdgeHard"></feComposite>
          <feGaussianBlur
            in="brownEdgeHard"
            stdDeviation="6"
            result="brownEdgeMask"></feGaussianBlur>
          <feComposite
            in="brownColorized"
            in2="brownEdgeMask"
            operator="in"
            result="brownEdge"></feComposite>
          <!-- Composite: green ring over base, then brown outer ring on top -->
          <feComposite
            in="greenEdge"
            in2="baseTinted"
            operator="over"
            result="withGreen"></feComposite>
          <feComposite in="brownEdge" in2="withGreen" operator="over"
          ></feComposite>
        </filter>

        <filter id="form-dried-filter" color-interpolation-filters="sRGB">
          <!-- Warm base tint — sun-bleached, earthy -->
          <feColorMatrix
            in="SourceGraphic"
            type="matrix"
            result="baseTinted"
            values="0.92 0.04 0 0 0.04  0.02 0.88 0.02 0 0.01  0 0.02 0.72 0 0  0 0 0 1 0"
          ></feColorMatrix>
          <!-- Papery surface grain — rough, matte, moisture-stripped -->
          <feColorMatrix
            in="baseTinted"
            type="saturate"
            values="0.70"
            result="baseTinted"></feColorMatrix>
          <feTurbulence
            type="fractalNoise"
            baseFrequency="0.38"
            numOctaves="4"
            seed="12"
            result="grain"></feTurbulence>
          <feColorMatrix in="grain" type="saturate" values="0" result="grain"
          ></feColorMatrix>
          <feComponentTransfer in="grain" result="grain">
            <feFuncR type="linear" slope="0.32" intercept="0.68"></feFuncR>
            <feFuncG type="linear" slope="0.32" intercept="0.68"></feFuncG>
            <feFuncB type="linear" slope="0.32" intercept="0.68"></feFuncB>
          </feComponentTransfer>
          <feComposite
            in="grain"
            in2="SourceAlpha"
            operator="in"
            result="clippedGrain"></feComposite>
          <feBlend
            in="baseTinted"
            in2="clippedGrain"
            mode="multiply"
            result="textured"></feBlend>
          <!-- Tight chalky edge ring — desiccated skin pulling inward -->
          <feColorMatrix
            in="SourceGraphic"
            type="matrix"
            result="crustColorized"
            values="0.48 0.16 0.06 0 0.06  0.10 0.44 0.06 0 0.03  0.04 0.06 0.30 0 0.01  0 0 0 1 0"
          ></feColorMatrix>
          <feComponentTransfer in="crustColorized" result="crustColorized">
            <feFuncR type="gamma" amplitude="1" exponent="1.35" offset="0"
            ></feFuncR>
            <feFuncG type="gamma" amplitude="1" exponent="1.50" offset="0"
            ></feFuncG>
            <feFuncB type="gamma" amplitude="1" exponent="1.80" offset="0"
            ></feFuncB>
          </feComponentTransfer>
          <feMorphology
            in="SourceAlpha"
            operator="erode"
            radius="3"
            result="eroded"></feMorphology>
          <feComposite
            in="SourceAlpha"
            in2="eroded"
            operator="out"
            result="edgeHard"></feComposite>
          <feGaussianBlur in="edgeHard" stdDeviation="4" result="edgeMask"
          ></feGaussianBlur>
          <feComposite
            in="crustColorized"
            in2="edgeMask"
            operator="in"
            result="colorizedEdge"></feComposite>
          <feComposite in="colorizedEdge" in2="textured" operator="over"
          ></feComposite>
        </filter>

        <filter id="form-smoked-filter" color-interpolation-filters="sRGB">
          <!-- Gray desaturated base — ashy, smoked surface -->
          <feColorMatrix
            in="SourceGraphic"
            type="matrix"
            result="baseTinted"
            values="0.82 0.10 0.08 0 0  0.08 0.80 0.10 0 0  0.06 0.08 0.84 0 0  0 0 0 1 0"
          ></feColorMatrix>
          <!-- Directional smoke streaks — asymmetric baseFrequency creates near-vertical char staining -->
          <feTurbulence
            type="fractalNoise"
            baseFrequency="0.02 0.15"
            numOctaves="3"
            seed="5"
            result="smokeStreaks"></feTurbulence>
          <feColorMatrix
            in="smokeStreaks"
            type="saturate"
            values="0"
            result="smokeStreaks"></feColorMatrix>
          <feComponentTransfer in="smokeStreaks" result="smokeStreaks">
            <feFuncR type="linear" slope="0.18" intercept="0.82"></feFuncR>
            <feFuncG type="linear" slope="0.18" intercept="0.82"></feFuncG>
            <feFuncB type="linear" slope="0.18" intercept="0.82"></feFuncB>
          </feComponentTransfer>
          <feComposite
            in="smokeStreaks"
            in2="SourceAlpha"
            operator="in"
            result="clippedStreaks"></feComposite>
          <feBlend
            in="baseTinted"
            in2="clippedStreaks"
            mode="multiply"
            result="baseTinted"></feBlend>
          <!-- Wide diffuse charcoal haze — smoke bleeds deep from the edge inward -->
          <feColorMatrix
            in="SourceGraphic"
            type="matrix"
            result="smokeColorized"
            values="0.22 0.06 0.06 0 0.04  0.06 0.22 0.06 0 0.04  0.06 0.06 0.24 0 0.06  0 0 0 1 0"
          ></feColorMatrix>
          <feComponentTransfer in="smokeColorized" result="smokeColorized">
            <feFuncR type="gamma" amplitude="1" exponent="0.75" offset="0"
            ></feFuncR>
            <feFuncG type="gamma" amplitude="1" exponent="0.75" offset="0"
            ></feFuncG>
            <feFuncB type="gamma" amplitude="1" exponent="0.70" offset="0"
            ></feFuncB>
          </feComponentTransfer>
          <feMorphology
            in="SourceAlpha"
            operator="erode"
            radius="12"
            result="eroded"></feMorphology>
          <feComposite
            in="SourceAlpha"
            in2="eroded"
            operator="out"
            result="edgeHard"></feComposite>
          <feGaussianBlur in="edgeHard" stdDeviation="16" result="edgeMask"
          ></feGaussianBlur>
          <feComposite
            in="smokeColorized"
            in2="edgeMask"
            operator="in"
            result="colorizedEdge"></feComposite>
          <feComposite in="colorizedEdge" in2="baseTinted" operator="over"
          ></feComposite>
        </filter>
      </defs>
    </svg>
    <canvas
      id="stars"
      aria-hidden="true"
      class="fixed inset-0 pointer-events-none z-0"
    >
    </canvas>
    <div class="orbs" aria-hidden="true">
      <div class="orb orb-1"></div>
      <div class="orb orb-2"></div>
      <div class="orb orb-3"></div>
      <div class="orb orb-4"></div>
      <div class="orb orb-5"></div>
    </div>
    <div class="relative z-10 flex flex-col min-h-screen">
      <Navigation />
      <main
        class="max-w-6xl mx-auto px-4 py-8 animate-fade-up flex-1 w-full pb-24 md:pb-8"
      >
        <slot />
      </main>
      <BottomTabBar />
      <footer
        class="relative z-10 border-t border-white/10 py-6 mt-8 mb-16 md:mb-0"
      >
        <div
          class="max-w-6xl mx-auto px-2 sm:px-4 flex items-center justify-center gap-2 text-sm text-zinc-400"
        >
          <span>Vibe-coded with love</span>
          <span class="text-zinc-600">·</span>
          <a
            href="https://github.com/Caleb-Ellis/bean-zodiac"
            target="_blank"
            rel="noopener noreferrer"
            class="flex items-center gap-1.5 text-zinc-400 hover:text-white transition-colors"
            aria-label="GitHub repository"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="16"
              height="16"
              viewBox="0 0 24 24"
              fill="currentColor"
              aria-hidden="true"

---
import Navigation from "../components/Navigation.astro";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "The Bean Zodiac",
  description = "Discover your Bean Zodiac and what the stars — and legumes — have in store.",
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link
      rel="icon"
      href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 100 100%22><text y=%22.9em%22 font-size=%2290%22>🫘</text></svg>"
    />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <title>
      {title === "The Bean Zodiac" ? title : `${title} — The Bean Zodiac`}
    </title>
  </head>
  <body class="bg-zinc-950 text-white min-h-screen font-sans">
    <!--
      Edge-only method filters. Each shares the same 6-step pipeline:
        1. feColorMatrix  — colour-shift the full image → colorized
        2. feComponentTransfer — adjust per-channel gamma → colorized
        3. feMorphology erode SourceAlpha → eroded (alpha shrunk inward)
        4. feComposite SourceAlpha out eroded → edgeHard (ring at boundary)
        5. feGaussianBlur edgeHard → edgeMask (soft gradient fade inward)
        6. feComposite colorized in edgeMask → colorizedEdge (effect at edges only)
        7. feComposite colorizedEdge over SourceGraphic → original interior + coloured edges
    -->
    <svg style="display: none" xmlns="http://www.w3.org/2000/svg">
      <defs>
        <filter id="method-roasted-filter" color-interpolation-filters="sRGB">
          <!-- Subtle overall warm-dark tint applied to the whole bean -->
          <feColorMatrix in="SourceGraphic" type="matrix" result="baseTinted" values="1.04 0 0 0 0.01  0 0.95 0 0 0  0 0 0.78 0 0  0 0 0 1 0"/>
          <!-- Ring 1: wide dark-orange that blurs inward -->
          <feColorMatrix in="SourceGraphic" type="matrix" result="brownColorized" values="0.65 0.20 0.03 0 0  0.15 0.48 0.03 0 0.02  0.02 0.03 0.12 0 0  0 0 0 1 0"/>
          <feComponentTransfer in="brownColorized" result="brownColorized">
            <feFuncR type="gamma" amplitude="1" exponent="1.3" offset="0"/>
            <feFuncG type="gamma" amplitude="1" exponent="1.4" offset="0"/>
            <feFuncB type="gamma" amplitude="1" exponent="1.6" offset="0"/>
          </feComponentTransfer>
          <feMorphology in="SourceAlpha" operator="erode" radius="10" result="brownEroded"/>
          <feComposite in="SourceAlpha" in2="brownEroded" operator="out" result="brownEdgeHard"/>
          <feGaussianBlur in="brownEdgeHard" stdDeviation="10" result="brownEdgeMask"/>
          <feComposite in="brownColorized" in2="brownEdgeMask" operator="in" result="brownEdge"/>
          <!-- Ring 2: thin dark crust right at the boundary, slightly blurred -->
          <feColorMatrix in="SourceGraphic" type="matrix" result="blackColorized" values="0.22 0.07 0.01 0 0  0.07 0.16 0.01 0 0  0.01 0.02 0.10 0 0  0 0 0 1 0"/>
          <feMorphology in="SourceAlpha" operator="erode" radius="2" result="blackEroded"/>
          <feComposite in="SourceAlpha" in2="blackEroded" operator="out" result="blackEdgeHard"/>
          <feGaussianBlur in="blackEdgeHard" stdDeviation="6" result="blackEdgeMask"/>
          <feComposite in="blackColorized" in2="blackEdgeMask" operator="in" result="blackEdge"/>
          <!-- Composite: brown ring over base, then black ring on top -->
          <feComposite in="brownEdge" in2="baseTinted" operator="over" result="withBrown"/>
          <feComposite in="blackEdge" in2="withBrown" operator="over"/>
        </filter>

        <filter id="method-fried-filter" color-interpolation-filters="sRGB">
          <!-- Subtle overall warm-red tint applied to the whole bean -->
          <feColorMatrix in="SourceGraphic" type="matrix" result="baseTinted" values="1.05 0 0 0 0.01  0 0.99 0 0 0  0 0 0.88 0 0  0 0 0 1 0"/>
          <!-- Stronger red-yellow shift for the edge crust, applied to SourceGraphic -->
          <feColorMatrix in="SourceGraphic" type="matrix" result="colorized" values="1.12 0.06 0 0 0.02  0.03 0.90 0.02 0 0  0 0 0.55 0 0  0 0 0 1 0"/>
          <feComponentTransfer in="colorized" result="colorized">
            <feFuncR type="gamma" amplitude="1" exponent="0.90" offset="0"/>
            <feFuncG type="gamma" amplitude="1" exponent="1.10" offset="0"/>
            <feFuncB type="gamma" amplitude="1" exponent="1.25" offset="0"/>
          </feComponentTransfer>
          <!-- Narrower, softer edge mask for a more subtle crust ring -->
          <feMorphology in="SourceAlpha" operator="erode" radius="4" result="eroded"/>
          <feComposite in="SourceAlpha" in2="eroded" operator="out" result="edgeHard"/>
          <feGaussianBlur in="edgeHard" stdDeviation="4" result="edgeMask"/>
          <feComposite in="colorized" in2="edgeMask" operator="in" result="colorizedEdge"/>
          <!-- Very thin blurred dark outer ring -->
          <feColorMatrix in="SourceGraphic" type="matrix" result="blackColorized" values="0.35 0.08 0.01 0 0  0.05 0.12 0.01 0 0  0.01 0.02 0.06 0 0  0 0 0 1 0"/>
          <feMorphology in="SourceAlpha" operator="erode" radius="1" result="blackEroded"/>
          <feComposite in="SourceAlpha" in2="blackEroded" operator="out" result="blackEdgeHard"/>
          <feGaussianBlur in="blackEdgeHard" stdDeviation="2" result="blackEdgeMask"/>
          <feComposite in="blackColorized" in2="blackEdgeMask" operator="in" result="blackEdge"/>
          <!-- Layer: colorized edge over base, then dark ring on top -->
          <feComposite in="colorizedEdge" in2="baseTinted" operator="over" result="withEdge"/>
          <feComposite in="blackEdge" in2="withEdge" operator="over"/>
        </filter>

        <filter id="method-boiled-filter" color-interpolation-filters="sRGB">
          <feColorMatrix type="matrix" result="colorized" values="0.70 0.10 0.05 0 0.07  0.05 0.72 0.08 0 0.05  0.05 0.10 0.85 0 0.05  0 0 0 1 0"/>
          <feComponentTransfer in="colorized" result="colorized">
            <feFuncR type="gamma" amplitude="1" exponent="0.7" offset="0"/>
            <feFuncG type="gamma" amplitude="1" exponent="0.7" offset="0"/>
            <feFuncB type="gamma" amplitude="1" exponent="0.7" offset="0"/>
          </feComponentTransfer>
          <feMorphology in="SourceAlpha" operator="erode" radius="10" result="eroded"/>
          <feComposite in="SourceAlpha" in2="eroded" operator="out" result="edgeHard"/>
          <feGaussianBlur in="edgeHard" stdDeviation="6" result="edgeMask"/>
          <feComposite in="colorized" in2="edgeMask" operator="in" result="colorizedEdge"/>
          <feComposite in="colorizedEdge" in2="SourceGraphic" operator="over"/>
        </filter>

        <filter id="method-fermented-filter" color-interpolation-filters="sRGB">
          <!-- Subtle green base tint on the whole bean -->
          <feColorMatrix in="SourceGraphic" type="matrix" result="baseTinted" values="0.99 0 0 0 0  0 1.01 0 0 0  0 0 0.96 0 0  0 0 0 1 0"/>
          <!-- Ring 1: wide dark-green that blurs inward -->
          <feColorMatrix in="SourceGraphic" type="matrix" result="greenColorized" values="0.65 0.06 0.02 0 0  0.05 0.68 0.05 0 0  0.02 0.04 0.52 0 0  0 0 0 1 0"/>
          <feComponentTransfer in="greenColorized" result="greenColorized">
            <feFuncR type="gamma" amplitude="1" exponent="1.15" offset="0"/>
            <feFuncG type="gamma" amplitude="1" exponent="1.10" offset="0"/>
            <feFuncB type="gamma" amplitude="1" exponent="1.20" offset="0"/>
          </feComponentTransfer>
          <feMorphology in="SourceAlpha" operator="erode" radius="10" result="greenEroded"/>
          <feComposite in="SourceAlpha" in2="greenEroded" operator="out" result="greenEdgeHard"/>
          <feGaussianBlur in="greenEdgeHard" stdDeviation="10" result="greenEdgeMask"/>
          <feComposite in="greenColorized" in2="greenEdgeMask" operator="in" result="greenEdge"/>
          <!-- Ring 2: outer brown-green crust, diffused -->
          <feColorMatrix in="SourceGraphic" type="matrix" result="brownColorized" values="0.62 0.08 0.01 0 0  0.05 0.58 0.01 0 0  0.01 0.02 0.38 0 0  0 0 0 1 0"/>
          <feMorphology in="SourceAlpha" operator="erode" radius="2" result="brownEroded"/>
          <feComposite in="SourceAlpha" in2="brownEroded" operator="out" result="brownEdgeHard"/>
          <feGaussianBlur in="brownEdgeHard" stdDeviation="6" result="brownEdgeMask"/>
          <feComposite in="brownColorized" in2="brownEdgeMask" operator="in" result="brownEdge"/>
          <!-- Composite: green ring over base, then brown outer ring on top -->
          <feComposite in="greenEdge" in2="baseTinted" operator="over" result="withGreen"/>
          <feComposite in="brownEdge" in2="withGreen" operator="over"/>
        </filter>
      </defs>
    </svg>
    <canvas
      id="stars"
      aria-hidden="true"
      class="fixed inset-0 pointer-events-none z-0"
    >
    </canvas>
    <div class="orbs" aria-hidden="true">
      <div class="orb orb-1"></div>
      <div class="orb orb-2"></div>
      <div class="orb orb-3"></div>
      <div class="orb orb-4"></div>
      <div class="orb orb-5"></div>
    </div>
    <div class="relative z-10 flex flex-col min-h-screen">
      <Navigation />
      <main class="max-w-6xl mx-auto px-4 py-8 animate-fade-up flex-1 w-full">
        <slot />
      </main>
      <footer class="relative z-10 border-t border-white/10 py-6 mt-8">
        <div
          class="max-w-6xl mx-auto px-2 sm:px-4 flex items-center justify-center gap-2 text-sm text-zinc-400"
        >
          <span>Vibe-coded with love</span>
          <span class="text-zinc-600">·</span>
          <a
            href="https://github.com/Caleb-Ellis/bean-zodiac"
            target="_blank"
            rel="noopener noreferrer"
            class="flex items-center gap-1.5 text-zinc-400 hover:text-white transition-colors"
            aria-label="GitHub repository"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="16"
              height="16"
              viewBox="0 0 24 24"
              fill="currentColor"
              aria-hidden="true"
            >
              <path
                d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0 1 12 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z"
              ></path>
            </svg>
            GitHub
          </a>
        </div>
      </footer>
    </div>
  </body>
</html>

<script>
  const canvas = document.getElementById("stars") as HTMLCanvasElement;
  const ctx = canvas.getContext("2d")!;

  interface Star {
    x: number;
    y: number;
    r: number;
    alpha: number;
    speed: number;
    phase: number;
  }

  let stars: Star[] = [];

  function resize() {
    canvas.width = window.innerWidth;
    canvas.height = window.innerHeight;
  }

  function seed() {
    stars = Array.from({ length: 180 }, () => ({
      x: Math.random() * canvas.width,
      y: Math.random() * canvas.height,
      r: Math.random() * 1.2 + 0.3,
      alpha: Math.random() * 0.25 + 0.1,
      speed: Math.random() * 0.6 + 0.2,
      phase: Math.random() * Math.PI * 2,
    }));
  }

  function draw(t: number) {
    ctx.clearRect(0, 0, canvas.width, canvas.height);
    for (const s of stars) {
      const twinkle = s.alpha + Math.sin(t * s.speed + s.phase) * 0.06;
      ctx.beginPath();
      ctx.arc(s.x, s.y, s.r, 0, Math.PI * 2);
      ctx.fillStyle = `rgba(255,255,255,${Math.max(0, twinkle)})`;
      ctx.fill();
    }
    requestAnimationFrame(draw);
  }

  resize();
  seed();
  window.addEventListener("resize", resize);
  requestAnimationFrame(draw);
</script>

<style>
  html,
  body {
    margin: 0;
    width: 100%;
    height: 100%;
  }

  #stars {
    width: 100%;
    height: 100%;
  }

  .orbs {
    position: fixed;
    inset: 0;
    overflow: hidden;
    pointer-events: none;
    z-index: 0;
  }

  .orb {
    position: absolute;
    border-radius: 50%;
    opacity: 0.25;
    animation: drift linear infinite;
  }

  .orb-1 {
    width: 700px;
    height: 700px;
    background: radial-gradient(
      circle,
      rgba(168, 85, 247, 0.8) 0%,
      rgba(168, 85, 247, 0.2) 40%,
      transparent 70%
    );
    top: -15%;
    left: -10%;
    animation-duration: 38s;
    animation-name: drift-1;
  }

  .orb-2 {
    width: 580px;
    height: 580px;
    background: radial-gradient(
      circle,
      rgba(239, 68, 68, 0.8) 0%,
      rgba(239, 68, 68, 0.2) 40%,
      transparent 70%
    );
    top: 25%;
    right: -12%;
    animation-duration: 47s;
    animation-name: drift-2;
  }

  .orb-3 {
    width: 520px;
    height: 520px;
    background: radial-gradient(
      circle,
      rgba(34, 197, 94, 0.8) 0%,
      rgba(34, 197, 94, 0.2) 40%,
      transparent 70%
    );
    bottom: -10%;
    left: 15%;
    animation-duration: 55s;
    animation-name: drift-3;
  }

  .orb-4 {
    width: 420px;
    height: 420px;
    background: radial-gradient(
      circle,
      rgba(245, 158, 11, 0.8) 0%,
      rgba(245, 158, 11, 0.2) 40%,
      transparent 70%
    );
    top: 50%;
    left: -8%;
    animation-duration: 42s;
    animation-name: drift-4;
  }

  .orb-5 {
    width: 620px;
    height: 620px;
    background: radial-gradient(
      circle,
      rgba(59, 130, 246, 0.8) 0%,
      rgba(59, 130, 246, 0.2) 40%,
      transparent 70%
    );
    top: 5%;
    right: 15%;
    animation-duration: 61s;
    animation-name: drift-5;
  }

  @keyframes drift-1 {
    0% {
      transform: translate(0, 0) scale(1);
    }
    25% {
      transform: translate(8vw, 12vh) scale(1.12);
    }
    50% {
      transform: translate(4vw, 22vh) scale(0.92);
    }
    75% {
      transform: translate(-4vw, 10vh) scale(1.08);
    }
    100% {
      transform: translate(0, 0) scale(1);
    }
  }

  @keyframes drift-2 {
    0% {
      transform: translate(0, 0) scale(1);
    }
    33% {
      transform: translate(-10vw, 8vh) scale(1.1);
    }
    66% {
      transform: translate(-6vw, -12vh) scale(0.88);
    }
    100% {
      transform: translate(0, 0) scale(1);
    }
  }

  @keyframes drift-3 {
    0% {
      transform: translate(0, 0) scale(1);
    }
    30% {
      transform: translate(6vw, -10vh) scale(1.15);
    }
    60% {
      transform: translate(-8vw, -6vh) scale(0.9);
    }
    100% {
      transform: translate(0, 0) scale(1);
    }
  }

  @keyframes drift-4 {
    0% {
      transform: translate(0, 0) scale(1);
    }
    40% {
      transform: translate(12vw, -8vh) scale(1.2);
    }
    70% {
      transform: translate(8vw, 6vh) scale(0.85);
    }
    100% {
      transform: translate(0, 0) scale(1);
    }
  }

  @keyframes drift-5 {
    0% {
      transform: translate(0, 0) scale(1);
    }
    20% {
      transform: translate(-5vw, 10vh) scale(0.9);
    }
    55% {
      transform: translate(-12vw, 5vh) scale(1.18);
    }
    80% {
      transform: translate(-4vw, -8vh) scale(1.05);
    }
    100% {
      transform: translate(0, 0) scale(1);
    }
  }
</style>

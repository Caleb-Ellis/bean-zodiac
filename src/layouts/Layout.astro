---
import { ClientRouter } from "astro:transitions";
import Navigation from "../components/Navigation.astro";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "The Bean Zodiac",
  description = "Discover your bean zodiac sign and what the stars — and legumes — have in store.",
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <title>
      {title === "The Bean Zodiac" ? title : `${title} — The Bean Zodiac`}
    </title>
    <ClientRouter />
  </head>
  <body>
    <Navigation />
    <main>
      <slot />
    </main>
  </body>
</html>

<style>
  html,
  body {
    margin: 0;
    width: 100%;
    height: 100%;
  }
</style>

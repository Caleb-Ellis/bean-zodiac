---
import Navigation from "../components/Navigation.astro";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "The Bean Zodiac",
  description = "Discover your Bean Zodiac and what the stars — and legumes — have in store.",
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link
      rel="icon"
      href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 100 100%22><text y=%22.9em%22 font-size=%2290%22>🫘</text></svg>"
    />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <title>
      {title === "The Bean Zodiac" ? title : `${title} — The Bean Zodiac`}
    </title>
  </head>
  <body class="bg-zinc-950 text-white min-h-screen font-sans">
    <!-- SVG filter defs for bean flavour effects -->
    <svg
      xmlns="http://www.w3.org/2000/svg"
      width="0"
      height="0"
      style="position:absolute;overflow:hidden"
      aria-hidden="true"
    >
      <defs>
        <filter
          id="umami-texture"
          color-interpolation-filters="sRGB"
          x="-5%"
          y="-5%"
          width="110%"
          height="110%"
        >
          <feTurbulence
            type="fractalNoise"
            baseFrequency="0.035"
            numOctaves="4"
            seed="3"
            result="noise"></feTurbulence>
          <feColorMatrix
            type="matrix"
            values="1 0.3 0 0 0  0.5 0.8 0 0 0  0 0.2 0 0 0  0 0 0 0.22 0"
            in="noise"
            result="tinted"></feColorMatrix>
          <feComposite
            in="tinted"
            in2="SourceGraphic"
            operator="in"
            result="masked"></feComposite>
          <feBlend in="SourceGraphic" in2="masked" mode="soft-light"></feBlend>
        </filter>
        <filter
          id="bitter-grain"
          color-interpolation-filters="sRGB"
          x="-5%"
          y="-5%"
          width="110%"
          height="110%"
        >
          <feTurbulence
            type="turbulence"
            baseFrequency="0.72"
            numOctaves="1"
            seed="9"
            result="noise"></feTurbulence>
          <feColorMatrix
            type="saturate"
            values="0"
            in="noise"
            result="grayNoise"></feColorMatrix>
          <feBlend
            in="SourceGraphic"
            in2="grayNoise"
            mode="overlay"
            result="blended"></feBlend>
          <feComposite in="blended" in2="SourceGraphic" operator="in"
          ></feComposite>
        </filter>
        <filter
          id="spicy-heat"
          color-interpolation-filters="sRGB"
          x="-10%"
          y="-10%"
          width="120%"
          height="120%"
        >
          <feTurbulence
            type="turbulence"
            baseFrequency="0.02 0.008"
            numOctaves="2"
            result="warp"
          >
            <animate
              attributeName="baseFrequency"
              values="0.02 0.008;0.028 0.012;0.02 0.008"
              dur="0.4s"
              repeatCount="indefinite"></animate>
          </feTurbulence>
          <feDisplacementMap
            in="SourceGraphic"
            in2="warp"
            scale="5"
            xChannelSelector="R"
            yChannelSelector="G"></feDisplacementMap>
        </filter>
      </defs>
    </svg>
    <div class="orbs" aria-hidden="true">
      <div class="orb orb-1"></div>
      <div class="orb orb-2"></div>
      <div class="orb orb-3"></div>
      <div class="orb orb-4"></div>
      <div class="orb orb-5"></div>
    </div>
    <div class="relative z-10">
      <Navigation />
      <main class="max-w-6xl mx-auto px-2 sm:px-4 py-8 animate-fade-up">
        <slot />
      </main>
    </div>
  </body>
</html>

<style>
  html,
  body {
    margin: 0;
    width: 100%;
    height: 100%;
  }

  .orbs {
    position: fixed;
    inset: 0;
    overflow: hidden;
    pointer-events: none;
    z-index: 0;
  }

  .orb {
    position: absolute;
    border-radius: 50%;
    filter: blur(80px);
    opacity: 0.4;
    animation: drift linear infinite;
  }

  .orb-1 {
    width: 520px;
    height: 520px;
    background: radial-gradient(circle, #a855f7, transparent 70%);
    top: -10%;
    left: -5%;
    animation-duration: 38s;
    animation-name: drift-1;
  }

  .orb-2 {
    width: 420px;
    height: 420px;
    background: radial-gradient(circle, #ef4444, transparent 70%);
    top: 30%;
    right: -8%;
    animation-duration: 47s;
    animation-name: drift-2;
  }

  .orb-3 {
    width: 380px;
    height: 380px;
    background: radial-gradient(circle, #22c55e, transparent 70%);
    bottom: -5%;
    left: 20%;
    animation-duration: 55s;
    animation-name: drift-3;
  }

  .orb-4 {
    width: 300px;
    height: 300px;
    background: radial-gradient(circle, #f59e0b, transparent 70%);
    top: 55%;
    left: -3%;
    animation-duration: 42s;
    animation-name: drift-4;
  }

  .orb-5 {
    width: 460px;
    height: 460px;
    background: radial-gradient(circle, #3b82f6, transparent 70%);
    top: 10%;
    right: 20%;
    animation-duration: 61s;
    animation-name: drift-5;
  }

  @keyframes drift-1 {
    0% {
      transform: translate(0, 0) scale(1);
    }
    25% {
      transform: translate(8vw, 12vh) scale(1.12);
    }
    50% {
      transform: translate(4vw, 22vh) scale(0.92);
    }
    75% {
      transform: translate(-4vw, 10vh) scale(1.08);
    }
    100% {
      transform: translate(0, 0) scale(1);
    }
  }

  @keyframes drift-2 {
    0% {
      transform: translate(0, 0) scale(1);
    }
    33% {
      transform: translate(-10vw, 8vh) scale(1.1);
    }
    66% {
      transform: translate(-6vw, -12vh) scale(0.88);
    }
    100% {
      transform: translate(0, 0) scale(1);
    }
  }

  @keyframes drift-3 {
    0% {
      transform: translate(0, 0) scale(1);
    }
    30% {
      transform: translate(6vw, -10vh) scale(1.15);
    }
    60% {
      transform: translate(-8vw, -6vh) scale(0.9);
    }
    100% {
      transform: translate(0, 0) scale(1);
    }
  }

  @keyframes drift-4 {
    0% {
      transform: translate(0, 0) scale(1);
    }
    40% {
      transform: translate(12vw, -8vh) scale(1.2);
    }
    70% {
      transform: translate(8vw, 6vh) scale(0.85);
    }
    100% {
      transform: translate(0, 0) scale(1);
    }
  }

  @keyframes drift-5 {
    0% {
      transform: translate(0, 0) scale(1);
    }
    20% {
      transform: translate(-5vw, 10vh) scale(0.9);
    }
    55% {
      transform: translate(-12vw, 5vh) scale(1.18);
    }
    80% {
      transform: translate(-4vw, -8vh) scale(1.05);
    }
    100% {
      transform: translate(0, 0) scale(1);
    }
  }
</style>
